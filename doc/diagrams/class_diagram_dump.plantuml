  -auth: String
  -userAgent: String
  -isActive$set: boolean
  -isActive$value: Boolean
  -lastUsed: Instant
  -createdAt: Instant
  -updatedAt: Instant
  --
  +toString()
  +id(id)
  +isActive(isActive)
  +build()
  +auth(auth)
  +user(user)
  +endpoint(endpoint)
  +userAgent(userAgent)
  +p256dh(p256dh)
  +createdAt(createdAt)
  +updatedAt(updatedAt)
  +lastUsed(lastUsed)
}


