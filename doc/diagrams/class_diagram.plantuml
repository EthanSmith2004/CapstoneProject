class RefreshTokenEntityBuilder <<Other>> {
  -id: Long
  -token: String
  -expiresAt: Instant
  -createdAt$set: boolean
  -createdAt$value: Instant
  -revoked$set: boolean
  -revoked$value: Boolean
  -revokedAt: Instant
  -user: UserEntity
  -lastUsed$set: boolean
  -lastUsed$value: Instant
  --
  +toString()
  +id(id)
  +build()
  +user(user)
  +token(token)
  +createdAt(createdAt)
  +expiresAt(expiresAt)
  +revoked(revoked)
  +revokedAt(revokedAt)
  +lastUsed(lastUsed)
}


