@startuml Class_Diagram
!define CONTROLLER_COLOR #E1F5FE
!define SERVICE_COLOR #F3E5F5
!define FACADE_COLOR #E8F5E8
!define SECURITY_COLOR #FFF3E0
!define ENTITY_COLOR #FFEBEE

title Class Diagram - Backend Application

' Define class stereotypes and colors
skinparam class {
  BackgroundColor<<Controller>> CONTROLLER_COLOR
  BackgroundColor<<Service>> SERVICE_COLOR
  BackgroundColor<<Facade>> FACADE_COLOR
  BackgroundColor<<Security>> SECURITY_COLOR
  BackgroundColor<<Entity>> ENTITY_COLOR
}


class UserEventEntityBuilder <<Other>> {
  -id: Long
  -time: Instant
  -user: UserEntity
  -eventType: UserEventType
  --
  +toString()
  +id(id)
  +time(time)
  +build()
  +user(user)
  +eventType(eventType)
}


class NotificationEntityBuilder <<Other>> {
  -id: Long
  -user: UserEntity
  -title: String
  -message: String
  -type: NotificationType
  -status$set: boolean
  -status$value: NotificationStatus
  -priority$set: boolean
  -priority$value: Integer
  -deepLinkUrl: String
  -imageUrl: String
  -relatedOrder: OrderEntity
  -scheduledFor: Instant
  -sentAt: Instant
  -deliveredAt: Instant
  -readAt: Instant
  -expiresAt: Instant
  -retryCount$set: boolean
  -retryCount$value: Integer
  -errorMessage: String
  -createdAt: Instant
  -updatedAt: Instant
  --
  +priority(priority)
  +type(type)
  +toString()
  +id(id)
  +status(status)
  +message(message)
  +build()
  +user(user)
  +readAt(readAt)
  +title(title)
  +errorMessage(errorMessage)
  +deliveredAt(deliveredAt)
  +scheduledFor(scheduledFor)
  +deepLinkUrl(deepLinkUrl)
  +relatedOrder(relatedOrder)
  +createdAt(createdAt)
  +updatedAt(updatedAt)
  +sentAt(sentAt)
  +retryCount(retryCount)
  +expiresAt(expiresAt)
  +imageUrl(imageUrl)
}


class UserFeedbackController <<Controller>> {
  -feedbackFacade: UserFeedbackFacade
  --
  +placeFeedback(feedback)
}


class UserDeviceEntityBuilder <<Other>> {
  -id: Long
  -user: UserEntity
  -endpoint: String
  -p256dh: String
  -auth: String
  -userAgent: String
  -isActive$set: boolean
  -isActive$value: Boolean
  -lastUsed: Instant
  -createdAt: Instant
  -updatedAt: Instant
  --
  +toString()
  +id(id)
  +isActive(isActive)
  +build()
  +auth(auth)
  +user(user)
  +endpoint(endpoint)
  +createdAt(createdAt)
  +updatedAt(updatedAt)
  +lastUsed(lastUsed)
  +p256dh(p256dh)
  +userAgent(userAgent)
}


class AllergyManagementController <<Controller>> {
  --
}


class NotificationController <<Controller>> {
  -notificationService: NotificationService
  -userService: UserService
  --
  +unsubscribe(subscription)
  +subscribe(subscription)
}


class OrderService <<Service>> {
  --
  +getUserOrders()
  +placeOrder(request)
}


class Role <<Other>> {
  --
  +values()
  +valueOf(name)
}


class UserDetailsServiceImpl <<Service>> {
  -userRepository: UserRepository
  --
  +loadUserByUsername(username)
}


class UserProfileFacade <<Service>> {
  --
  +updateUserProfile(request)
  +createUserProfile(request)
  +getUserProfile()
}


class FinanceService <<Service>> {
  --
  +searchUsersPaginated(search, page, size)
  +getTransactionsPaginated(page, size)
  +getCurrentUserAccount()
  +getUserDetail(userId)
  +bulkLoadCredit(request)
}


class OrderItemFeedbackEntityBuilder <<Other>> {
  -id: Long
  -orderItem: OrderItemEntity
  -rating: Integer
  -feedback: String
  -createdAt: Instant
  -updatedAt: Instant
  --
  +toString()
  +id(id)
  +build()
  +feedback(feedback)
  +createdAt(createdAt)
  +updatedAt(updatedAt)
  +rating(rating)
  +orderItem(orderItem)
}


class AdminNotificationController <<Controller>> {
  -notificationService: NotificationService
  --
  +sendToAll(notification)
  +sendToUser(userId, notification)
}


class UserEntityBuilder <<Other>> {
  -id: Long
  -firstName: String
  -lastName: String
  -email: String
  -password: String
  -roles: Set
  -accountNonExpired$set: boolean
  -accountNonExpired$value: boolean
  -accountNonLocked$set: boolean
  -accountNonLocked$value: boolean
  -credentialsNonExpired$set: boolean
  -credentialsNonExpired$value: boolean
  -enabled$set: boolean
  -enabled$value: boolean
  -createdAt: Instant
  -updatedAt: Instant
  --
  +toString()
  +id(id)
  +enabled(enabled)
  +build()
  +lastName(lastName)
  +credentialsNonExpired(credentialsNonExpired)
  +createdAt(createdAt)
  +updatedAt(updatedAt)
  +accountNonLocked(accountNonLocked)
  +accountNonExpired(accountNonExpired)
  +password(password)
  +roles(roles)
  +firstName(firstName)
  +email(email)
}


class UserOrderFacade <<Service>> {
  --
  +getUserOrders()
  +cancelOrder(orderId)
  +placeOrder(request)
  +editOrder(request)
  +payOrder(orderId)
}


class WebSecurityConfig <<Security>> {
  -userDetailsService: UserDetailsService
  -unauthorizedHandler: AuthEntryPointJwt
  --
  +corsConfigurationSource()
  +authenticationProvider()
  +authenticationManager(authConfig)
  +authenticationJwtTokenFilter()
  +filterChain(http)
  +passwordEncoder()
}


class ResidenceManagementService <<Service>> {
  --
}


class UserFinanceFacade <<Service>> {
  --
  +getTransactionsPaginated(page, size)
  +getCurrentUserAccount()
}


class AuthService <<Service>> {
  -authenticationManager: AuthenticationManager
  -userRepository: UserRepository
  -encoder: PasswordEncoder
  -jwtUtils: JwtUtils
  -refreshTokenService: RefreshTokenService
  -userEventService: UserEventService
  --
  +authenticateUser(loginRequest)
  +registerUser(signUpRequest)
  +refreshToken(refreshTokenValue)
  +logout(refreshTokenValue)
  -getAuthResponse(userDetails, jwt, refreshToken)
}


class ReportEntityBuilder <<Other>> {
  -id: Long
  -name: String
  -description: String
  -type: ReportType
  -status$set: boolean
  -status$value: ReportStatus
  -requestedBy: UserEntity
  -fileUrl: String
  -fileName: String
  -fileSize: Long
  -mimeType: String
  -parameters: Map
  -dateFrom: Instant
  -dateTo: Instant
  -scheduled$set: boolean
  -scheduled$value: Boolean
  -processingStartedAt: Instant
  -processingCompletedAt: Instant
  -errorMessage: String
  -lastDownloadedAt: Instant
  -createdAt: Instant
  -updatedAt: Instant
  --
  +name(name)
  +type(type)
  +toString()
  +fileName(fileName)
  +id(id)
  +status(status)
  +parameters(parameters)
  +build()
  +description(description)
  +processingStartedAt(processingStartedAt)
  +processingCompletedAt(processingCompletedAt)
  +errorMessage(errorMessage)
  +createdAt(createdAt)
  +updatedAt(updatedAt)
  +dateFrom(dateFrom)
  +dateTo(dateTo)
  +fileSize(fileSize)
  +mimeType(mimeType)
  +fileUrl(fileUrl)
  +scheduled(scheduled)
  +requestedBy(requestedBy)
  +lastDownloadedAt(lastDownloadedAt)
}


class MenuService <<Service>> {
  --
  +getAllUpcomingMenuItems()
  +getMenuItemsPaginated(page, size)
  +searchMenuItemsPaginated(search, page, size)
  +getMenuItemDetail(itemId)
  +getAllActiveMenuItems()
  +getMenu()
  +createMenuItem(request)
  +updateMenuItem(id, request)
}


class TransactionAuditType <<Other>> {
  --
  +values()
  +valueOf(name)
}


class JwtUtils <<Security>> {
  -jwtSecret: String
  -jwtExpirationMs: int
  --
  -key()
  +getUserNameFromJwtToken(token)
  +generateTokenFromUsername(username, expiration)
  +validateJwtToken(authToken)
  +generateJwtToken(authentication)
  +getJwtExpirationMs()
}


