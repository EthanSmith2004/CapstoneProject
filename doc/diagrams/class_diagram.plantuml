' Dependencies - Controllers to Services/Facades
UserFeedbackController --> UserFeedbackFacade : uses
NotificationController --> NotificationService : uses
NotificationController --> UserDetailsServiceImpl : uses
NotificationController --> UserProfileFacade : uses
NotificationController --> UserOrderFacade : uses
NotificationController --> UserFinanceFacade : uses
NotificationController --> MenuService : uses
NotificationController --> UserService : uses
NotificationController --> UserSettingsFacade : uses
NotificationController --> UserEventService : uses
NotificationController --> UserFeedbackFacade : uses
AdminNotificationController --> NotificationService : uses
AdminAuditController --> AuditService : uses
UserAccountController --> UserFinanceFacade : uses
AdminUserController --> UserDetailsServiceImpl : uses
AdminUserController --> UserProfileFacade : uses
AdminUserController --> UserOrderFacade : uses
AdminUserController --> UserFinanceFacade : uses
AdminUserController --> MenuService : uses
AdminUserController --> UserService : uses
AdminUserController --> UserSettingsFacade : uses
AdminUserController --> UserEventService : uses
AdminUserController --> UserFeedbackFacade : uses
UserProfileController --> UserProfileFacade : uses
AuthController --> AuthService : uses
AdminReportController --> ReportService : uses
UserOrderController --> UserOrderFacade : uses
AdminFinanceController --> FinanceService : uses
AdminFinanceController --> UserFinanceFacade : uses
UserMenuController --> MenuService : uses
AdminMenuController --> MenuService : uses
ListController --> ListService : uses
UserSettingsController --> UserSettingsFacade : uses

' Facades to Services

@enduml